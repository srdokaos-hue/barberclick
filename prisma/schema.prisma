// ============================================================
// BarberClick SaaS — Schema Prisma Completo
// PostgreSQL 16 | Multi-tenant por barbershop_id
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────

enum Plan {
  STARTER
  PRO
  ELITE
}

enum Role {
  ADMIN
  BARBER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
}

enum ItemType {
  SERVICE
  PRODUCT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum AlertStatus {
  OPEN
  RESOLVED
  SNOOZED
}

// ─── TENANT (SaaS root) ──────────────────────────────────────

model Barbershop {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique           // ex: "barbearia-do-silva"
  logoUrl     String?
  coverUrl    String?
  whatsapp    String?
  instagram   String?
  address     String?
  plan        Plan     @default(STARTER)
  active      Boolean  @default(true)
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  barbers              Barber[]
  clients              Client[]
  services             Service[]
  products             Product[]
  appointments         Appointment[]
  financialTransactions FinancialTransaction[]
  scheduleConfig       ScheduleConfig?

  @@map("barbershops")
}

// ─── USUÁRIOS ────────────────────────────────────────────────

model Barber {
  id            String     @id @default(uuid())
  barbershopId  String
  name          String
  email         String     @unique
  passwordHash  String
  phone         String?
  avatarUrl     String?
  role          Role       @default(BARBER)
  commissionPct Decimal    @default(50) @db.Decimal(5, 2) // ex: 70.00 = 70%
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([barbershopId])
  @@map("barbers")
}

// ─── CLIENTES ────────────────────────────────────────────────

model Client {
  id                 String    @id @default(uuid())
  barbershopId       String
  name               String
  phone              String
  email              String?
  notes              String?
  lastVisitAt        DateTime?
  returnIntervalDays Int       @default(25) // gatilho de lembrete
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  barbershop       Barbershop       @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  returnReminders  ReturnReminder[]

  @@index([barbershopId])
  @@index([phone])
  @@map("clients")
}

// ─── SERVIÇOS ────────────────────────────────────────────────

model Service {
  id            String   @id @default(uuid())
  barbershopId  String
  name          String                          // ex: "Corte + Barba"
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  durationMin   Int      @default(30)           // duração em minutos
  imageUrl      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  barbershop       Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointmentItems AppointmentItem[]

  @@index([barbershopId])
  @@map("services")
}

// ─── PRODUTOS ────────────────────────────────────────────────

model Product {
  id                String   @id @default(uuid())
  barbershopId      String
  name              String                       // ex: "Pomada Matte 100g"
  description       String?
  imageUrl          String?
  salePrice         Decimal  @db.Decimal(10, 2)
  costPrice         Decimal  @db.Decimal(10, 2)
  stockQty          Int      @default(0)
  lowStockThreshold Int      @default(3)         // gatilho de alerta
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  barbershop       Barbershop       @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointmentItems AppointmentItem[]
  stockAlerts      StockAlert[]

  @@index([barbershopId])
  @@map("products")
}

// ─── AGENDAMENTOS ────────────────────────────────────────────

model Appointment {
  id              String            @id @default(uuid())
  barbershopId    String
  barberId        String
  clientId        String
  scheduledAt     DateTime          // data + hora exata
  endsAt          DateTime          // calculado: scheduledAt + soma das durações
  status          AppointmentStatus @default(PENDING)
  totalAmount     Decimal           @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus     @default(PENDING)
  paymentRef      String?           // ID externo Stripe/PIX
  orderBumpAccepted Boolean         @default(false)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  barbershop           Barbershop             @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber               Barber                 @relation(fields: [barberId], references: [id])
  client               Client                 @relation(fields: [clientId], references: [id])
  items                AppointmentItem[]
  financialTransaction FinancialTransaction?
  returnReminder       ReturnReminder?

  @@index([barbershopId, scheduledAt])
  @@index([barberId, scheduledAt])
  @@index([clientId])
  @@map("appointments")
}

// ─── ITENS DO AGENDAMENTO ─────────────────────────────────────

model AppointmentItem {
  id            String   @id @default(uuid())
  appointmentId String
  serviceId     String?  // null se for produto
  productId     String?  // null se for serviço
  itemType      ItemType
  name          String   // snapshot do nome no momento da venda
  unitPrice     Decimal  @db.Decimal(10, 2)
  quantity      Int      @default(1)
  discountPct   Decimal  @default(0) @db.Decimal(5, 2) // ex: 15.00 = 15%
  subtotal      Decimal  @db.Decimal(10, 2)           // calculado
  isOrderBump   Boolean  @default(false)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id])
  product     Product?    @relation(fields: [productId], references: [id])

  @@index([appointmentId])
  @@map("appointment_items")
}

// ─── TRANSAÇÕES FINANCEIRAS ──────────────────────────────────

model FinancialTransaction {
  id            String          @id @default(uuid())
  barbershopId  String
  appointmentId String?         @unique // null para despesas manuais
  type          TransactionType
  grossAmount   Decimal         @db.Decimal(10, 2) // faturamento bruto
  costAmount    Decimal         @default(0) @db.Decimal(10, 2) // custo dos produtos
  netAmount     Decimal         @db.Decimal(10, 2) // lucro líquido
  category      String?         // ex: "produto", "servico", "despesa-fixa"
  description   String?
  barberId      String?         // para rastreio de comissão
  commissionAmt Decimal?        @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())

  barbershop  Barbershop  @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([barbershopId, createdAt])
  @@index([barberId])
  @@map("financial_transactions")
}

// ─── LEMBRETES DE RETORNO ────────────────────────────────────

model ReturnReminder {
  id              String         @id @default(uuid())
  clientId        String
  appointmentId   String         @unique
  daysInterval    Int            // dias configurados pelo barbeiro
  scheduledFor    DateTime       // data/hora de disparo do job
  status          ReminderStatus @default(PENDING)
  messageTemplate String?        // template customizável
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime       @default(now())

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([scheduledFor, status])
  @@index([clientId])
  @@map("return_reminders")
}

// ─── ALERTAS DE ESTOQUE ──────────────────────────────────────

model StockAlert {
  id          String      @id @default(uuid())
  productId   String
  currentQty  Int
  threshold   Int
  status      AlertStatus @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status])
  @@map("stock_alerts")
}

// ─── CONFIGURAÇÃO DE AGENDA ──────────────────────────────────

model ScheduleConfig {
  id            String   @id @default(uuid())
  barbershopId  String   @unique
  // dias da semana disponíveis (JSON array): [1,2,3,4,5] = seg a sex
  workDays      Json     @default("[1,2,3,4,5,6]")
  openTime      String   @default("09:00") // HH:mm
  closeTime     String   @default("19:00")
  lunchStart    String?
  lunchEnd      String?
  slotDurationMin Int    @default(30)
  maxAdvanceDays  Int    @default(30) // máximo de dias à frente para agendar
  updatedAt     DateTime @updatedAt

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@map("schedule_configs")
}
